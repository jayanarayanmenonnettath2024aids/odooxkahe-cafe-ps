# ======================
# Cafe POS Backend
# ======================

# App
APP_NAME=CafePOS
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://cafepos:cafepos_secret@localhost:5432/cafepos_db

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# Admin Seed
ADMIN_EMAIL=admin@cafepos.com
ADMIN_PASSWORD=admin123

# Server
HOST=0.0.0.0
PORT=8000
